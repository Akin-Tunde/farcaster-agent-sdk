{
  "name": "farcaster-agent-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building, reading, executing, and streaming Farcaster Agent actions",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/index.d.ts",
      "import": "./dist/manifest/index.mjs",
      "require": "./dist/manifest/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.mjs",
      "require": "./dist/compiler/index.js"
    },
    "./executor": {
      "types": "./dist/executor/index.d.ts",
      "import": "./dist/executor/index.mjs",
      "require": "./dist/executor/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.mjs",
      "require": "./dist/events/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["farcaster", "agent", "sdk", "web3", "mini-app", "ai"],
  "license": "MIT",
  "dependencies": {
    "viem": "^2.21.0",
    "zod": "^3.23.8",
    "eventemitter3": "^5.0.1",
    "ts-morph": "^23.0.0",
    "tinyglobby": "^0.2.9",
    "farcaster-agent-compiler": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "viem": { "optional": true }
  }
}
